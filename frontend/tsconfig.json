{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@payments/*": [
        "./src/domains/payments/*"
      ],
      "@merchants/*": [
        "./src/domains/merchants/*"
      ],
      "@wallets/*": [
        "./src/domains/wallets/*"
      ],
      "@analytics/*": [
        "./src/domains/analytics/*"
      ],
      "@settings/*": [
        "./src/domains/settings/*"
      ],
      "@developers/*": [
        "./src/domains/developers/*"
      ],
      "@shared/*": [
        "./src/shared/*"
      ],
      "@ui/*": [
        "./src/ui/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "**/*.stories.ts",
    "**/*.stories.tsx",
    ".storybook",
    "lib/wallet-connect.ts",
    "service-worker.ts",
    "src/wallets/hardware/**/*",
    "src/components/hardware-wallet-connect.tsx"
  ]
}
