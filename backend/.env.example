NODE_ENV=development
PORT=3001
LOG_LEVEL=info
LOG_LEVELS=webhooks:debug
CORS_ALLOWED_ORIGINS=http://localhost:3000
JOBS_ENABLED=true
QUEUE_ENABLED=true
STELLAR_NETWORK=testnet
RATE_LIMIT_FREE=100
RATE_LIMIT_PRO=300
RATE_LIMIT_ENTERPRISE=1000
RATE_LIMIT_WINDOW_MS=900000
COMPRESSION_THRESHOLD=1024

# Token Bucket Rate Limiting
# REDIS_URL=redis://localhost:6379
# RATE_LIMIT_BURST_FREE=10
# RATE_LIMIT_BURST_PRO=50
# RATE_LIMIT_BURST_ENTERPRISE=200
# RATE_LIMIT_REFILL_FREE=1
# RATE_LIMIT_REFILL_PRO=5
# RATE_LIMIT_REFILL_ENTERPRISE=20

# IP Allowlist (comma-separated CIDR ranges)
# IP_ALLOWLIST=10.0.0.0/8,192.168.1.0/24
# IP_ALLOWLIST_ENABLED=false
# IP_ALLOWLIST_BYPASS_ENABLED=false
# IP_ALLOWLIST_BYPASS_EXPIRY_MS=1800000

# Stripe card payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Database Read Replicas
# DB_READ_REPLICA_URLS=postgresql://user:pass@replica1:5432/db,postgresql://user:pass@replica2:5432/db
# DB_REPLICA_MAX_LAG_MS=5000

# Notification Channels
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=password
# SMTP_FROM=noreply@agenticpay.com
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# SLACK_BOT_TOKEN=xoxb-your-token
# NOTIFICATION_WEBHOOK_URL=https://your-webhook-endpoint.com/notify
# NOTIFICATION_WEBHOOK_SECRET=your-webhook-secret

# Redis Cluster
# REDIS_CLUSTER_NODES=redis1:6379,redis2:6379,redis3:6379
# REDIS_CLUSTER_MAX_REDIRECTIONS=3
# REDIS_CLUSTER_RETRY_ATTEMPTS=3
# REDIS_CLUSTER_RETRY_DELAY=500
